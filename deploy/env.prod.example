# Copy this file to .env on the production server and replace every value.
# Keep the real .env only on the server or in secret storage.

# Public HTTPS endpoint. DNS A/AAAA records must point to the server before first start.
WMS_PUBLIC_DOMAIN=wms.example.com
WMS_HTTP_PORT=80
WMS_HTTPS_PORT=443

# PostgreSQL container bootstrap.
POSTGRES_DB=wms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-long-random-password

# API database connection inside Docker network.
DATABASE_URL=postgresql+psycopg_async://postgres:replace-with-long-random-password@db:5432/wms

# Background jobs.
CELERY_BROKER_URL=redis://redis:6379/0

# API security. Generate unique production values.
# JWT must be at least 16 characters (enforced by backend settings).
JWT_SECRET_KEY=replace-with-long-random-secret-at-least-16-chars
# Optional Fernet key (urlsafe base64). If unsure, generate a real Fernet key for production.
WMS_SECRETS_FERNET_KEY=replace-with-real-fernet-key-or-leave-empty
