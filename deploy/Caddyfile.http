:80 {
  encode gzip zstd

  handle_path /api/* {
    reverse_proxy api:8000
  }

  redir /seller /seller/

  handle /seller* {
    root * /srv
    @seller_spa {
      not path /assets/*
      not path /favicon.svg
      not path /favicon-seller.svg
    }
    header @seller_spa Cache-Control "no-cache, no-store, must-revalidate"
    try_files {path} /seller/index.html
    file_server
  }

  handle {
    root * /srv
    @spa_html path /index.html /seller/index.html
    header @spa_html Cache-Control "no-cache, no-store, must-revalidate"
    try_files {path} /index.html
    file_server
  }
}
