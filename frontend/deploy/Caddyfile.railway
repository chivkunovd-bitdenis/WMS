:{$PORT:8080} {
  encode gzip zstd

  handle_path /api/* {
    reverse_proxy {$WMS_API_UPSTREAM:http://api:8000}
  }

  redir /seller /seller/

  handle /seller* {
    root * /srv
    try_files {path} /seller/index.html
    file_server
  }

  handle {
    root * /srv
    @spa_html path /index.html /seller/index.html
    header @spa_html Cache-Control "no-cache, no-store, must-revalidate"
    try_files {path} /index.html
    file_server
  }
}
